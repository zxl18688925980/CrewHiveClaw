{"input":{"command":"curl -s -L --max-time 15 -A \"Mozilla/5.0 (Linux; Android 11; Pixel 5) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/90.0.4430.91 Mobile Safari/537.36\" \"https://mp.weixin.qq.com/s?__biz=MjM5ODIyNjA5Mg==&mid=2652412713&idx=1&sn=2b9a4272dbcc62804ef4f62eb4697003\" | python3 -c \"\nimport sys, re\nhtml = sys.stdin.read()\n# 提取标题\ntitle = re.search(r'<h1[^>]*class=\\\"rich_media_title\\\"[^>]*>(.*?)</h1>', html, re.S)\nif title:\n    print('标题:', re.sub(r'<[^>]+>', '', title.group(1)).strip())\n# 提取正文\ncontent = re.search(r'id=\\\"js_content\\\"[^>]*>(.*?)</div>', html, re.S)\nif content:\n    text = re.sub(r'<[^>]+>', '', content.group(1))\n    text = re.sub(r'\\s+', ' ', text).strip()\n    print('正文预览:', text[:500])\nelse:\n    print('未找到正文，HTML长度:', len(html))\n    print('HTML片段:', html[:300])\n\"\n"},"level":"info","message":"Main 调用工具","timestamp":"2026-03-23T07:29:22.031Z","tool":"run_shell"}
{"input":{"command":"curl -s -L --max-time 15 -A \"Mozilla/5.0 (Linux; Android 11; Pixel 5) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/90.0.4430.91 Mobile Safari/537.36\" \"https://mp.weixin.qq.com/s?__biz=MjM5ODIyNjA5Mg==&mid=2652412713&idx=1&sn=2b9a4272dbcc62804ef4f62eb4697003\" | python3 -c \"\nimport sys, re\nhtml = sys.stdin.read()\n# 看看关键字段\nfor kw in ['verify', '环境异常', '请在微信客户端', 'window.__INIT_PROPS__', 'msg_title']:\n    if kw in html:\n        print('Found:', kw)\n# 尝试找meta og:title\nog = re.search(r'property=\\\"og:title\\\" content=\\\"([^\\\"]+)\\\"', html)\nif og:\n    print('og:title:', og.group(1))\n# 看看有没有 window 变量带文章内容\nprops = re.search(r'window\\.__INIT_PROPS__\\s*=\\s*(\\{.*?\\});', html, re.S)\nif props:\n    print('INIT_PROPS found, len:', len(props.group(1)))\nprint('---关键内容---')\nprint(html[5000:6000])\n\"\n"},"level":"info","message":"Main 调用工具","timestamp":"2026-03-23T07:29:32.280Z","tool":"run_shell"}
