{"input":{"code":"\n# 读取文件，找到 Step 3 的正则，打印上下文确认行号\nwith open('/Users/xinbinanshan/HomeAI/crewclaw/daemons/entrances/wecom/index.js', 'r') as f:\n    lines = f.readlines()\n\nfor i, line in enumerate(lines, 1):\n    if 'play_addr' in line or 'url_list' in line and 'mp4' in line:\n        print(f\"{i}: {line}\", end='')\n","interpreter":"python3"},"level":"info","message":"Main 调用工具","timestamp":"2026-03-29T07:50:08.643Z","tool":"exec_script"}
{"input":{"code":"\nfilepath = '/Users/xinbinanshan/HomeAI/crewclaw/daemons/entrances/wecom/index.js'\n\nwith open(filepath, 'r', encoding='utf8') as f:\n    content = f.read()\n\n# 旧的两行正则（有缩进）\nold = '''    const cdnRaw = html.match(/\"play_addr\":\\\\s*\\\\{[^}]*\"url_list\":\\\\s*\\\\[\"([^\"]+)\"/)\n                || html.match(/\"url_list\":\\\\s*\\\\[\"(https:\\\\/\\\\/[^\"]*\\\\.mp4[^\"]*)\"/);\\n    const cdnUrl = cdnRaw ? decodeUnicode(cdnRaw[1]) : null;'''\n\n# 新的提取逻辑：不用 [^}]* 跨越嵌套，直接找 url_list 中第一个含视频域名的 URL\nnew = '''    // 提取 CDN 视频 URL：不用 [^}]* 跨越嵌套 JSON，直接全文扫 url_list\n    // 抖音 CDN 域名：v3-web.douyinvod.com / v26.muscdn.com / aweme.snssdk.com 等\n    const cdnUrlMatch = html.match(/\"url_list\"\\\\s*:\\\\s*\\\\[\\\\s*\"(https:\\\\/\\\\/[^\"]+\\\\.mp4[^\"]*)\"/i)\n                     || html.match(/\"url_list\"\\\\s*:\\\\s*\\\\[\\\\s*\"(https:\\\\/\\\\/[^\"]+(?:douyinvod|muscdn|snssdk|tiktok|bytecdn|ixigua)[^\"]*)\"/i)\n                     || html.match(/\"url_list\"\\\\s*:\\\\s*\\\\[\\\\s*\"(https:\\\\/\\\\/[^\"]{20,})\"/);\n    const cdnUrl = cdnUrlMatch ? decodeUnicode(cdnUrlMatch[1]) : null;'''\n\nif old in content:\n    content = content.replace(old, new)\n    with open(filepath, 'w', encoding='utf8') as f:\n        f.write(content)\n    print(\"✅ 替换成功\")\nelse:\n    # 尝试更宽松匹配\n    import re\n    m = re.search(r'const cdnRaw = html\\.match.*?\\n.*?url_list.*?;\\n.*?const cdnUrl', content, re.DOTALL)\n    if m:\n        print(\"未精确匹配，找到的区域：\")\n        print(repr(content[m.start():m.end()+50]))\n    else:\n        print(\"❌ 完全没找到，打印211-215行：\")\n        lines = content.split('\\n')\n        for i in range(209, 215):\n            print(f\"{i+1}: {repr(lines[i])}\")\n","interpreter":"python3"},"level":"info","message":"Main 调用工具","timestamp":"2026-03-29T07:50:22.458Z","tool":"exec_script"}
{"input":{"code":"\nfilepath = '/Users/xinbinanshan/HomeAI/crewclaw/daemons/entrances/wecom/index.js'\n\nwith open(filepath, 'r', encoding='utf8') as f:\n    content = f.read()\n\n# 找 Step 4 之前、cdnUrl 之后的 if 判断，在其前面插入 yt-dlp fallback\nold_step4 = '''    // Step 4: 音频 ASR\n    let transcript = '';\n    if (cdnUrl && fs.existsSync(WHISPER_CLI) && fs.existsSync(WHISPER_MODEL)) {\n      transcript = await transcribeDouyinAudio(cdnUrl);\n    }'''\n\nnew_step4 = '''    // Step 4: 音频 ASR\n    // cdnUrl fallback：正则未拿到时，用 yt-dlp 提取直链（免登录，支持大多数抖音视频）\n    let resolvedCdnUrl = cdnUrl;\n    if (!resolvedCdnUrl) {\n      try {\n        const { execFileSync } = require('child_process');\n        const ytOut = execFileSync('/opt/homebrew/bin/yt-dlp', [\n          '--get-url', '--quiet', '--no-warnings',\n          '-f', 'bestaudio/best',\n          `https://www.douyin.com/video/${videoId}`,\n        ], { encoding: 'utf8', timeout: 20000 }).trim();\n        if (ytOut && ytOut.startsWith('http')) {\n          resolvedCdnUrl = ytOut.split('\\\\n')[0].trim();\n          logger.info('scrapeDouyinContent: yt-dlp fallback 获取 CDN URL 成功', { videoId });\n        }\n      } catch (ytErr) {\n        logger.warn('scrapeDouyinContent: yt-dlp fallback 也失败', { error: ytErr.message });\n      }\n    }\n    let transcript = '';\n    if (resolvedCdnUrl && fs.existsSync(WHISPER_CLI) && fs.existsSync(WHISPER_MODEL)) {\n      transcript = await transcribeDouyinAudio(resolvedCdnUrl);\n    }'''\n\nif old_step4 in content:\n    content = content.replace(old_step4, new_step4)\n    # 同时把 Step 5 里的 cdnUrl 换成 resolvedCdnUrl\n    content = content.replace(\n        'if (withFrames && cdnUrl) {\\n      frameDesc = await analyzeDouyinFrames(cdnUrl);',\n        'if (withFrames && resolvedCdnUrl) {\\n      frameDesc = await analyzeDouyinFrames(resolvedCdnUrl);'\n    )\n    with open(filepath, 'w', encoding='utf8') as f:\n        f.write(content)\n    print(\"✅ Step 4 fallback 插入成功\")\nelse:\n    print(\"❌ 未找到 Step 4 区域，打印当前 cdnUrl 后的内容：\")\n    idx = content.find('const resolvedCdnUrl = cdnUrl')\n    if idx == -1:\n        idx = content.find('Step 4')\n    print(repr(content[idx:idx+400]))\n","interpreter":"python3"},"level":"info","message":"Main 调用工具","timestamp":"2026-03-29T07:50:38.665Z","tool":"exec_script"}
