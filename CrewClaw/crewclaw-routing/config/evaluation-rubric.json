{
  "_comment": "Main 评估体系 rubric 配置。评分逻辑在代码（确定性），阈值在此配置（可调整），历史在 JSONL（可追溯）。",
  "_scoring": "0=缺失/不可用, 1=较差/需干预, 2=偏低/需关注, 3=合格/可接受, 4=良好/近优, 5=完美/最佳",
  "_direction": "higher_better = raw >= threshold → score; lower_better = raw <= threshold → score; enum = direct mapping",

  "layers": {
    "L0": {
      "label": "Agent基础设施",
      "pass_threshold": 3.0,
      "items": {
        "process_alive": {
          "name": "Watchdog 进程存活",
          "weight": 1.5,
          "direction": "enum",
          "map": { "online": 5, "stopped": 2, "missing": 0 }
        },
        "kuzu_data": {
          "name": "Kuzu 知识图谱数据量（Fact 数）",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [10, 3], [1, 2], [0, 0]]
        },
        "chromadb_conversations": {
          "name": "ChromaDB 对话记忆可达",
          "weight": 1.0,
          "direction": "enum",
          "map": { "reachable": 5, "unreachable": 0 }
        },
        "data_freshness": {
          "name": "家人档案新鲜度（小时）",
          "weight": 0.8,
          "direction": "lower_better",
          "thresholds": [[24, 5], [48, 4], [72, 2], [168, 1], [9999, 0]]
        },
        "chromadb_decisions": {
          "name": "ChromaDB 决策记忆可达",
          "weight": 0.8,
          "direction": "enum",
          "map": { "reachable": 5, "unreachable": 0 }
        },
        "disk_space": {
          "name": "磁盘使用率（%）",
          "weight": 1.0,
          "direction": "lower_better",
          "thresholds": [[70, 5], [85, 4], [90, 3], [95, 2], [101, 0]]
        },
        "gateway_latency": {
          "name": "Gateway 响应延迟（ms）",
          "weight": 0.8,
          "direction": "lower_better",
          "thresholds": [[500, 5], [1000, 4], [2000, 3], [3000, 2], [99999, 0]]
        },
        "chromadb_latency": {
          "name": "ChromaDB 响应延迟（ms）",
          "weight": 0.6,
          "direction": "lower_better",
          "thresholds": [[200, 5], [500, 4], [1000, 3], [2000, 2], [99999, 0]]
        },
        "memory_usage": {
          "name": "内存活跃使用率（%）",
          "weight": 0.5,
          "direction": "lower_better",
          "thresholds": [[60, 5], [75, 4], [85, 3], [90, 2], [101, 1]]
        },
        "collab_edges_readiness": {
          "name": "L3 协作边就绪信号",
          "weight": 0.3,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 1]]
        }
      }
    },

    "L1": {
      "label": "Agent行为质量",
      "pass_threshold": 3.0,
      "items": {
        "lucas_output_quality": {
          "name": "Lucas 输出合规率（问题率越低越好）",
          "weight": 1.5,
          "direction": "lower_better",
          "thresholds": [[5, 5], [10, 4], [20, 3], [30, 2], [101, 1]]
        },
        "agent_interactions": {
          "name": "Andy/Lisa 交互活跃度",
          "weight": 0.8,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "family_inject": {
          "name": "家人档案注入文件",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[3, 5], [1, 3], [0, 0]]
        },
        "distillation_output": {
          "name": "每日蒸馏产出（design/impl learning）",
          "weight": 1.0,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "pattern_accumulation": {
          "name": "Kuzu 行为模式积累（has_pattern）",
          "weight": 0.8,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "main_heartbeat": {
          "name": "Main HEARTBEAT 正常",
          "weight": 0.5,
          "direction": "enum",
          "map": { "ok": 5, "missing": 0 }
        },
        "sub_agent_activity": {
          "name": "子 Agent 活跃度（影子/evaluator）",
          "weight": 0.3,
          "direction": "higher_better",
          "thresholds": [[3, 5], [1, 3], [0, 1]]
        }
      }
    },

    "L2": {
      "label": "Engineering Anything",
      "pass_threshold": 2.5,
      "_doc": "三角色闭环交付力。Frontend Agent感知需求→Designer设计→Implementor实现，基础设施层保证可靠性。",
      "items": {
        "task_type_coverage": {
          "name": "任务类型覆盖度（成功交付过的任务类型数）",
          "weight": 1.5,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [2, 3], [1, 2], [0, 0]]
        },
        "delivery_success_rate": {
          "name": "端到端交付成功率（%）",
          "weight": 1.5,
          "direction": "higher_better",
          "thresholds": [[90, 5], [70, 4], [50, 2], [1, 1], [0, 0]]
        },
        "deliverable_diversity": {
          "name": "交付物多样性（类型数：app/代码/消息/研究/洞察…）",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[6, 5], [4, 4], [2, 3], [1, 2], [0, 0]]
        },
        "pipeline_health": {
          "name": "三角色流水线健康（有效任务比例%）",
          "weight": 1.2,
          "direction": "higher_better",
          "_doc": "completed/(completed+failed)，cancelled/queued不计入分母；数据来自task-registry",
          "thresholds": [[80, 5], [60, 4], [40, 3], [1, 2], [0, 0]]
        }
      }
    },

    "L3": {
      "label": "组织协作进化",
      "pass_threshold": 2.0,
      "_doc": "四层机制：①成员画像（从交互蒸馏）②关系图谱（Kuzu协作边）③影子Agent（演进环+访客）④跨成员感知（协作蒸馏）",
      "items": {
        "member_profile": {
          "name": "成员画像质量（档案含蒸馏信息的比例%）",
          "weight": 1.2,
          "_dimension": "D1_MemberProfile",
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [1, 2], [0, 0]]
        },
        "collab_edges": {
          "name": "协作关系图谱边（Kuzu）",
          "weight": 1.5,
          "_dimension": "D2_RelationGraph",
          "direction": "higher_better",
          "thresholds": [[20, 5], [10, 4], [5, 3], [1, 2], [0, 0]]
        },
        "shadow_interactions": {
          "name": "影子Agent演进记录（ChromaDB）",
          "weight": 1.0,
          "_dimension": "D3_ShadowAgent",
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 1]]
        },
        "visitor_registry": {
          "name": "访客影子状态",
          "weight": 0.8,
          "_dimension": "D3_ShadowAgent",
          "direction": "enum",
          "map": { "active": 5, "dormant_only": 3, "none": 1 }
        },
        "relationship_distill": {
          "name": "跨成员感知蒸馏运行状态",
          "weight": 0.8,
          "_dimension": "D4_CrossMember",
          "direction": "enum",
          "map": { "recent": 5, "exists": 3, "never": 1 }
        },
        "member_enhancement": {
          "name": "成员增强效果（档案含协作信息比例%）",
          "weight": 0.8,
          "_dimension": "D4_CrossMember",
          "direction": "higher_better",
          "thresholds": [[50, 5], [1, 3], [0, 1]]
        }
      }
    },

    "L4": {
      "label": "系统自进化",
      "pass_threshold": 2.0,
      "_doc": "两层：①系统层自我改进（Andy主力：蒸馏/结晶/DPO/巡检）②模型层内化（DPO+SFT/本地路由比例上升）。完成标志：同类错误趋势下降，AGENTS.md规则条数持续减少，本地路由比例持续上升",
      "items": {
        "dpo_accumulation": {
          "name": "DPO 模式距内化阈值进度（%）",
          "weight": 1.5,
          "_layer": "model",
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [20, 3], [1, 2], [0, 0]]
        },
        "agents_md_maturity": {
          "name": "AGENTS.md 规则收敛度（规则总条数，越少越成熟）",
          "weight": 1.0,
          "_layer": "system",
          "_doc": "规则条数少 = 更多行为内化到权重，不靠外部注入。lower_better。基线~180条（L1完成期），目标随L4深化持续下降",
          "direction": "lower_better",
          "thresholds": [[100, 5], [150, 4], [200, 3], [250, 2], [9999, 1]]
        },
        "routing_evolution": {
          "name": "路由阈值进化（本地路由比例%）",
          "weight": 1.0,
          "_layer": "system",
          "_doc": "route-events.jsonl中local路由占总路由的比例，越高说明本地模型承担越多",
          "direction": "higher_better",
          "thresholds": [[50, 5], [20, 4], [5, 3], [1, 2], [0, 1]]
        },
        "local_model_ready": {
          "name": "本地模型就绪",
          "weight": 0.8,
          "_layer": "model",
          "direction": "enum",
          "map": { "ready": 5, "partial": 3, "none": 0 }
        }
      }
    }
  }
}
