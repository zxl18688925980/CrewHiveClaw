{
  "_comment": "Main 评估体系 rubric 配置。评分逻辑在代码（确定性），阈值在此配置（可调整），历史在 JSONL（可追溯）。",
  "_scoring": "0=缺失/不可用, 1=较差/需干预, 2=偏低/需关注, 3=合格/可接受, 4=良好/近优, 5=完美/最佳",
  "_direction": "higher_better = raw >= threshold → score; lower_better = raw <= threshold → score; enum = direct mapping",

  "layers": {
    "L0": {
      "label": "基础设施",
      "pass_threshold": 3.0,
      "items": {
        "process_alive": {
          "name": "Watchdog 进程存活",
          "weight": 1.5,
          "direction": "enum",
          "map": { "online": 5, "stopped": 2, "missing": 0 }
        },
        "kuzu_data": {
          "name": "Kuzu 知识图谱数据量（Fact 数）",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [10, 3], [1, 2], [0, 0]]
        },
        "chromadb_conversations": {
          "name": "ChromaDB 对话记忆可达",
          "weight": 1.0,
          "direction": "enum",
          "map": { "reachable": 5, "unreachable": 0 }
        },
        "data_freshness": {
          "name": "家人档案新鲜度（小时）",
          "weight": 0.8,
          "direction": "lower_better",
          "thresholds": [[24, 5], [48, 4], [72, 2], [168, 1], [9999, 0]]
        },
        "chromadb_decisions": {
          "name": "ChromaDB 决策记忆可达",
          "weight": 0.8,
          "direction": "enum",
          "map": { "reachable": 5, "unreachable": 0 }
        },
        "disk_space": {
          "name": "磁盘使用率（%）",
          "weight": 1.0,
          "direction": "lower_better",
          "thresholds": [[70, 5], [85, 4], [90, 3], [95, 2], [101, 0]]
        },
        "gateway_latency": {
          "name": "Gateway 响应延迟（ms）",
          "weight": 0.8,
          "direction": "lower_better",
          "thresholds": [[500, 5], [1000, 4], [2000, 3], [3000, 2], [99999, 0]]
        },
        "chromadb_latency": {
          "name": "ChromaDB 响应延迟（ms）",
          "weight": 0.6,
          "direction": "lower_better",
          "thresholds": [[200, 5], [500, 4], [1000, 3], [2000, 2], [99999, 0]]
        },
        "memory_usage": {
          "name": "内存活跃使用率（%）",
          "weight": 0.5,
          "direction": "lower_better",
          "thresholds": [[60, 5], [75, 4], [85, 3], [90, 2], [101, 1]]
        },
        "collab_edges_readiness": {
          "name": "L3 协作边就绪信号",
          "weight": 0.3,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 1]]
        }
      }
    },

    "L1": {
      "label": "行为质量",
      "pass_threshold": 3.0,
      "items": {
        "lucas_output_quality": {
          "name": "Lucas 输出合规率（问题率越低越好）",
          "weight": 1.5,
          "direction": "lower_better",
          "thresholds": [[5, 5], [10, 4], [20, 3], [30, 2], [101, 1]]
        },
        "agent_interactions": {
          "name": "Andy/Lisa 交互活跃度",
          "weight": 0.8,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "family_inject": {
          "name": "家人档案注入文件",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[3, 5], [1, 3], [0, 0]]
        },
        "distillation_output": {
          "name": "每日蒸馏产出（design/impl learning）",
          "weight": 1.0,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "pattern_accumulation": {
          "name": "Kuzu 行为模式积累（has_pattern）",
          "weight": 0.8,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "main_heartbeat": {
          "name": "Main HEARTBEAT 正常",
          "weight": 0.5,
          "direction": "enum",
          "map": { "ok": 5, "missing": 0 }
        },
        "sub_agent_activity": {
          "name": "子 Agent 活跃度（影子/evaluator）",
          "weight": 0.3,
          "direction": "higher_better",
          "thresholds": [[3, 5], [1, 3], [0, 1]]
        }
      }
    },

    "L2": {
      "label": "系统自进化",
      "pass_threshold": 2.5,
      "items": {
        "skill_candidates": {
          "name": "进化信号积累（skill-candidates）",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 0]]
        },
        "dpo_candidates": {
          "name": "DPO 负例积累（dpo-candidates）",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 0]]
        },
        "andy_heartbeat_check": {
          "name": "Andy HEARTBEAT 巡检时效（小时）",
          "weight": 1.2,
          "direction": "lower_better",
          "thresholds": [[26, 5], [30, 4], [48, 3], [168, 1], [9999, 0]]
        },
        "opencode_success_rate": {
          "name": "opencode 成功率（%）",
          "weight": 1.5,
          "direction": "higher_better",
          "thresholds": [[90, 5], [70, 4], [50, 2], [1, 1], [0, 0]]
        },
        "codebase_patterns": {
          "name": "代码库洞察积累",
          "weight": 0.8,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 1]]
        },
        "skill_count": {
          "name": "Skill 总量（三角色合计）",
          "weight": 0.5,
          "direction": "higher_better",
          "thresholds": [[20, 5], [10, 4], [5, 3], [0, 2]]
        }
      }
    },

    "L3": {
      "label": "组织协作进化",
      "pass_threshold": 2.0,
      "items": {
        "collab_edges": {
          "name": "协作关系边（Kuzu）",
          "weight": 1.5,
          "direction": "higher_better",
          "thresholds": [[20, 5], [10, 4], [5, 3], [1, 2], [0, 0]]
        },
        "shadow_interactions": {
          "name": "影子交互记录（ChromaDB）",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 1]]
        },
        "visitor_registry": {
          "name": "访客影子状态",
          "weight": 0.8,
          "direction": "enum",
          "map": { "active": 5, "dormant_only": 3, "none": 1 }
        },
        "relationship_distill": {
          "name": "关系蒸馏运行状态",
          "weight": 0.8,
          "direction": "enum",
          "map": { "recent": 5, "exists": 3, "never": 1 }
        },
        "member_enhancement": {
          "name": "成员增强效果（档案含协作信息比例）",
          "weight": 0.8,
          "direction": "higher_better",
          "thresholds": [[50, 5], [1, 3], [0, 1]]
        }
      }
    },

    "L4": {
      "label": "深度学习",
      "pass_threshold": 2.0,
      "items": {
        "dpo_accumulation": {
          "name": "DPO 模式距内化阈值进度（%）",
          "weight": 1.5,
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [20, 3], [1, 2], [0, 0]]
        },
        "l2_intervention": {
          "name": "L2 临时干预存在（幻觉禁令）",
          "weight": 1.0,
          "direction": "enum",
          "map": { "exists": 5, "missing": 1 }
        },
        "local_model_ready": {
          "name": "本地模型就绪",
          "weight": 1.0,
          "direction": "enum",
          "map": { "ready": 5, "partial": 3, "none": 0 }
        }
      }
    }
  }
}
