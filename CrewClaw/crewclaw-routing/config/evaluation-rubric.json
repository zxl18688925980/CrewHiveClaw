{
  "_comment": "Main 评估体系 rubric 配置。评分逻辑在代码（确定性），阈值在此配置（可调整），历史在 JSONL（可追溯）。",
  "_scoring": "0=缺失/不可用, 1=较差/需干预, 2=偏低/需关注, 3=合格/可接受, 4=良好/近优, 5=完美/最佳",
  "_direction": "higher_better = raw >= threshold → score; lower_better = raw <= threshold → score; enum = direct mapping",

  "layers": {
    "L0": {
      "label": "基础设施稳定性",
      "_doc": "进程稳定性与关键服务可达性。L0 是一切的前提——进程挂了，上面的 L1~L5 全是空转。重点评估：PM2 进程全部 online + 重启频率低、Gateway/ChromaDB/Ollama 可达且延迟正常、磁盘/内存未超限。",
      "pass_threshold": 3.5,
      "items": {
        "pm2_processes": {
          "name": "PM2 关键进程全部 online（wecom-entrance / chromadb / gateway-watchdog / cloudflared-tunnel）",
          "weight": 2.0,
          "_type": "core",
          "direction": "enum",
          "map": { "all_online": 5, "partial": 2, "critical_down": 0 }
        },
        "process_stability": {
          "name": "进程稳定性（关键进程累计重启次数，越低越好）",
          "weight": 1.5,
          "_type": "core",
          "direction": "lower_better",
          "thresholds": [[5, 5], [15, 4], [30, 3], [60, 2], [9999, 1]]
        },
        "gateway_health": {
          "name": "Gateway 可达且响应延迟（ms）",
          "weight": 1.5,
          "_type": "core",
          "direction": "lower_better",
          "thresholds": [[500, 5], [1000, 4], [2000, 3], [3000, 2], [99999, 0]]
        },
        "chromadb_health": {
          "name": "ChromaDB 可达且响应延迟（ms）",
          "weight": 1.2,
          "_type": "core",
          "direction": "lower_better",
          "thresholds": [[200, 5], [500, 4], [1000, 3], [2000, 2], [99999, 0]]
        },
        "aibot_ws": {
          "name": "企业微信 aibot WebSocket 连接状态",
          "weight": 1.2,
          "_type": "core",
          "direction": "enum",
          "map": { "authenticated": 5, "connected": 3, "disconnected": 0 }
        },
        "ollama_health": {
          "name": "Ollama 本地模型服务可达",
          "weight": 0.8,
          "_type": "core",
          "direction": "enum",
          "map": { "reachable": 5, "unreachable": 2 }
        },
        "disk_space": {
          "name": "磁盘使用率（%）",
          "weight": 0.8,
          "_type": "core",
          "direction": "lower_better",
          "thresholds": [[70, 5], [85, 4], [90, 3], [95, 2], [101, 0]]
        },
        "memory_usage": {
          "name": "内存活跃使用率（%）",
          "weight": 0.5,
          "_type": "core",
          "direction": "lower_better",
          "thresholds": [[60, 5], [75, 4], [85, 3], [90, 2], [101, 1]]
        }
      }
    },

    "L1": {
      "label": "Agent记忆与认知质量",
      "_doc": "写入侧质量：四维度记忆写入健康（语义/时间/实体/因果）× 三角色；蒸馏管道产出（design_learning/impl_learning/Kuzu facts/inject.md）。L0 基础设施健康是 L1 正常工作的前提。",
      "pass_threshold": 3.0,
      "items": {
        "memory_write_health": {
          "name": "四维度记忆写入健康（三角色 embedding 有效率最低值%）",
          "weight": 1.5,
          "_dimension": "semantic+temporal+entity+causal",
          "_type": "core",
          "direction": "higher_better",
          "thresholds": [[90, 5], [80, 4], [60, 3], [40, 2], [0, 1]]
        },
        "distillation_output": {
          "name": "每日蒸馏产出（Andy design_learning + Lisa impl_learning）",
          "weight": 1.2,
          "_type": "core",
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "family_inject": {
          "name": "家人档案注入文件（Kuzu→inject.md 蒸馏产物）",
          "weight": 1.0,
          "_type": "core",
          "direction": "higher_better",
          "thresholds": [[3, 5], [1, 3], [0, 0]]
        },
        "kuzu_data": {
          "name": "Kuzu 知识图谱数据量（Fact 数）",
          "weight": 1.0,
          "_type": "core",
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [10, 3], [1, 2], [0, 0]]
        },
        "data_freshness": {
          "name": "家人档案新鲜度（小时）",
          "weight": 0.8,
          "_type": "core",
          "direction": "lower_better",
          "thresholds": [[24, 5], [48, 4], [72, 2], [168, 1], [9999, 0]]
        },
        "temporal_degradation": {
          "name": "时间分层退化检测（历史期 vs 近期 embedding 有效率差值 pp，越小越好）",
          "weight": 1.0,
          "_type": "core",
          "_doc": "近30天 embedding 有效率 - 90天前 embedding 有效率。正值=历史期更差，说明早期写入质量低。负值=无退化。教师工具：真实数据直接对比，不合成。",
          "direction": "lower_better",
          "thresholds": [[0, 5], [10, 4], [20, 3], [30, 2], [101, 1]]
        }
      }
    },

    "L2": {
      "label": "Agent人格完整度",
      "_doc": "召回侧质量：记忆召回语义相关性；上下文工程形成人格连续性（家人档案注入在L1写入，L2消费）；Skill 自动沉淀与积累；行为模式结晶（Kuzu has_pattern）。",
      "pass_threshold": 3.0,
      "items": {
        "memory_recall_quality": {
          "name": "三角色语义召回质量（avg cosine distance，越低越好）",
          "weight": 1.5,
          "_dimension": "semantic+temporal+entity+causal",
          "_type": "core",
          "direction": "lower_better",
          "thresholds": [[0.35, 5], [0.5, 4], [0.65, 3], [0.8, 2], [2.0, 1]]
        },
        "skill_accumulation": {
          "name": "Skill 自动沉淀（native skills 总数）",
          "weight": 1.0,
          "_type": "core",
          "direction": "higher_better",
          "thresholds": [[20, 5], [10, 4], [5, 3], [1, 2], [0, 1]]
        },
        "lucas_output_quality": {
          "name": "Lucas 输出合规率（问题率越低越好）",
          "weight": 1.5,
          "direction": "lower_better",
          "thresholds": [[5, 5], [10, 4], [20, 3], [30, 2], [101, 1]]
        },
        "agent_interactions": {
          "name": "Andy/Lisa 交互活跃度",
          "weight": 0.8,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "pattern_accumulation": {
          "name": "Kuzu 行为模式积累（has_pattern）",
          "weight": 0.8,
          "direction": "enum",
          "map": { "both_active": 5, "one_active": 3, "none_active": 0 }
        },
        "main_heartbeat": {
          "name": "Main HEARTBEAT 正常",
          "weight": 0.5,
          "direction": "enum",
          "map": { "ok": 5, "missing": 0 }
        },
        "sub_agent_activity": {
          "name": "子 Agent 活跃度（影子/evaluator）",
          "weight": 0.3,
          "direction": "higher_better",
          "thresholds": [[3, 5], [1, 3], [0, 1]]
        },
        "teacher_hit_rate": {
          "name": "教师召回测试（90天前真实消息 Hit Rate@3 %）",
          "weight": 1.2,
          "_type": "core",
          "_doc": "外循环教师测试：从 conversations 取90天前真实用户消息，embed后查 top-3，看原始记录是否被召回。测不出=仪表盘；测出来=真实能力。",
          "direction": "higher_better",
          "thresholds": [[100, 5], [67, 4], [33, 3], [1, 2], [0, 1]]
        },
        "unresolved_requirements": {
          "name": "未落地需求数（outcome='' 且 >30天，越少越好）",
          "weight": 0.8,
          "_type": "core",
          "_doc": "外循环教师测试：承诺追踪。requirements 集合 outcome='' 且写入 >30天，代表系统承诺但未落地的需求。0=完美，越多=遗忘越严重。",
          "direction": "lower_better",
          "thresholds": [[0, 5], [3, 4], [5, 3], [10, 2], [999, 1]]
        }
      }
    },

    "L3": {
      "label": "Engineering Anything",
      "pass_threshold": 2.5,
      "_doc": "三角色闭环交付力。Frontend Agent感知需求→Designer设计→Implementor实现，基础设施层保证可靠性。",
      "items": {
        "task_type_coverage": {
          "name": "任务类型覆盖度（成功交付过的任务类型数）",
          "weight": 1.5,
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [2, 3], [1, 2], [0, 0]]
        },
        "delivery_success_rate": {
          "name": "端到端交付成功率（%）",
          "weight": 1.5,
          "direction": "higher_better",
          "thresholds": [[90, 5], [70, 4], [50, 2], [1, 1], [0, 0]]
        },
        "deliverable_diversity": {
          "name": "交付物多样性（类型数：app/代码/消息/研究/洞察…）",
          "weight": 1.0,
          "direction": "higher_better",
          "thresholds": [[6, 5], [4, 4], [2, 3], [1, 2], [0, 0]]
        },
        "pipeline_health": {
          "name": "三角色流水线健康（有效任务比例%）",
          "weight": 1.2,
          "direction": "higher_better",
          "_doc": "completed/(completed+failed)，cancelled/queued不计入分母；数据来自task-registry",
          "thresholds": [[80, 5], [60, 4], [40, 3], [1, 2], [0, 0]]
        }
      }
    },

    "L4": {
      "label": "组织协作进化",
      "pass_threshold": 2.0,
      "_doc": "四层机制：①成员画像（从交互蒸馏）②关系图谱（Kuzu协作边）③影子Agent（演进环+访客）④跨成员感知（协作蒸馏）",
      "items": {
        "member_profile": {
          "name": "成员画像质量（档案含蒸馏信息的比例%）",
          "weight": 1.2,
          "_dimension": "D1_MemberProfile",
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [1, 2], [0, 0]]
        },
        "collab_edges": {
          "name": "协作关系图谱边（Kuzu）",
          "weight": 1.5,
          "_dimension": "D2_RelationGraph",
          "direction": "higher_better",
          "thresholds": [[20, 5], [10, 4], [5, 3], [1, 2], [0, 0]]
        },
        "shadow_interactions": {
          "name": "影子Agent演进记录（ChromaDB）",
          "weight": 1.0,
          "_dimension": "D3_ShadowAgent",
          "direction": "higher_better",
          "thresholds": [[10, 5], [5, 4], [1, 3], [0, 1]]
        },
        "visitor_registry": {
          "name": "访客影子状态",
          "weight": 0.8,
          "_dimension": "D3_ShadowAgent",
          "direction": "enum",
          "map": { "active": 5, "dormant_only": 3, "none": 1 }
        },
        "relationship_distill": {
          "name": "跨成员感知蒸馏运行状态",
          "weight": 0.8,
          "_dimension": "D4_CrossMember",
          "direction": "enum",
          "map": { "recent": 5, "exists": 3, "never": 1 }
        },
        "member_enhancement": {
          "name": "成员增强效果（档案含协作信息比例%）",
          "weight": 0.8,
          "_dimension": "D4_CrossMember",
          "direction": "higher_better",
          "thresholds": [[50, 5], [1, 3], [0, 1]]
        }
      }
    },

    "L5": {
      "label": "系统自进化",
      "pass_threshold": 2.0,
      "_doc": "两层：①系统层自我改进（Andy主力：蒸馏/结晶/DPO/巡检）②模型层内化（DPO+SFT/本地路由比例上升）。完成标志：同类错误趋势下降，AGENTS.md规则条数持续减少，本地路由比例持续上升。",
      "items": {
        "dpo_accumulation": {
          "name": "DPO 模式距内化阈值进度（%）",
          "weight": 1.5,
          "_layer": "model",
          "direction": "higher_better",
          "thresholds": [[100, 5], [50, 4], [20, 3], [1, 2], [0, 0]]
        },
        "agents_md_maturity": {
          "name": "AGENTS.md 规则收敛度（规则总条数，越少越成熟）",
          "weight": 1.0,
          "_layer": "system",
          "_doc": "规则条数少 = 更多行为内化到权重，不靠外部注入。lower_better。基线~180条（L2完成期），目标随L5深化持续下降",
          "direction": "lower_better",
          "thresholds": [[100, 5], [150, 4], [200, 3], [250, 2], [9999, 1]]
        },
        "routing_evolution": {
          "name": "路由阈值进化（本地路由比例%）",
          "weight": 1.0,
          "_layer": "system",
          "_doc": "route-events.jsonl中local路由占总路由的比例，越高说明本地模型承担越多",
          "direction": "higher_better",
          "thresholds": [[50, 5], [20, 4], [5, 3], [1, 2], [0, 1]]
        },
        "local_model_ready": {
          "name": "本地模型就绪",
          "weight": 0.8,
          "_layer": "model",
          "direction": "enum",
          "map": { "ready": 5, "partial": 3, "none": 0 }
        }
      }
    }
  }
}
